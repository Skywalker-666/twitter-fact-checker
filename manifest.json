{
  "manifest_version": 3,
  "name": "Gemini Twitter Fact-Checker",
  "version": "1.1",
  "permissions": ["storage"],
  "host_permissions": ["https://generativelanguage.googleapis.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://twitter.com/*", "https://x.com/*"],
      "js": ["content.js"],
      "css": ["style.css"]
    }
  ]
}